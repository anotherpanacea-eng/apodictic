      "id": "i:C0",
      "type": "I-node",
      "text": "The city should publish a heat-response plan at /Users/example/authored-path.",
      "source_ref": "§2 C0"
    },
    {
      "id": "i:C1",
      "type": "I-node",
      "text": "Heat emergencies are recurring public-health events.",
      "source_ref": "§2 C1"
    },
    {
      "id": "i:C1.support",
      "type": "I-node",
      "text": "Five years of emergency-department records show recurring heat spikes.",
      "source_ref": "§3 C1"
    },
    {
      "id": "i:C2",
      "type": "I-node",
      "text": "A published plan makes agency responsibilities inspectable.",
      "source_ref": "§2 C2"
    },
    {
      "id": "i:C2.support",
      "type": "I-node",
      "text": "The existing emergency plan already assigns named agency roles.",
      "source_ref": "§3 C2"
    },
    {
      "id": "i:O1",
      "type": "I-node",
      "text": "A short record may reflect one anomalous weather cycle.",
      "source_ref": "§6 O1"
    },
    {
      "id": "i:O2",
      "type": "I-node",
      "text": "Publication alone cannot guarantee compliance.",
      "source_ref": "§6 O2"
    },
    {
      "id": "i:O3",
      "type": "I-node",
      "text": "A cooling-center-only strategy is cheaper.",
      "source_ref": "§6 O3"
