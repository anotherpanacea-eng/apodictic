.DS_Store
*.bak
*.tmp
.codex-build-tmp*/
.antigravity-build-tmp*/
dist/
/apodictic.plugin

# Generated host workspaces — built from plugins/ and published as release
# assets by .github/workflows/release.yml (decision: GitHub #52, Option B).
# Regenerate locally with: node scripts/build-codex.mjs / build-antigravity.mjs
/codex/
/antigravity/
Outputs/
issues/
**/.apodictic_run/
**/__pycache__/
**/.pytest_cache/
*.pyc

# Local-only review-planning + working notes
# (process/methodology filenames only; no manuscript references in any
# gitignored file or folder name)
docs/blind-review-protocol.md
docs/eval-harness-spec.md
docs/model-capability-review-spec.md
docs/model-upgrade-backlog.md
docs/prompt-inventory.md
docs/2026-04-25_codex-final-review-prompt.md
docs/review-log/

# Local-only fixture manifests. Manifests name specific manuscripts and
# therefore cannot ship in-repo. Wildcard + allowlist keeps the
# .gitignore itself free of manuscript-trackable filenames.
evals/manifests/*.md
!evals/manifests/README.md
!evals/manifests/fixture-manifest-template.md

# Eval run outputs. Gitignored by default — may contain private-fixture
# outputs or model artifacts. Permitted synthetic/public-domain outputs are
# committed explicitly (git add -f) per the fixture-provenance policy.
# Wildcard + README allowlist mirrors the manifests pattern above.
evals/results/*
!evals/results/README.md
